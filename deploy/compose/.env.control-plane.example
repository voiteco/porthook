# Copy this file to .env.control-plane and replace every change-me value.

PORTHOOK_POSTGRES_PASSWORD=change-me-postgres-password
PORTHOOK_CONTROL_ADMIN_TOKEN=change-me-admin-token
PORTHOOK_CONTROL_VALIDATOR_TOKEN=change-me-validator-token

PORTHOOK_ROOT_DOMAIN=localhost
PORTHOOK_PUBLIC_URL=http://localhost:8080

PORTHOOK_PUBLIC_PORT=8080
PORTHOOK_AGENT_PORT=8081
PORTHOOK_CONTROL_PORT=8082
