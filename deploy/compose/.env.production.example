# Copy this file to .env.production and replace every change-me value.
# Do not commit the generated .env.production file.
#
# Production deployments should use separate generated values for the
# Postgres password, control-plane admin token, and gateway validator token.

PORTHOOK_POSTGRES_PASSWORD=change-me-postgres-password
PORTHOOK_CONTROL_ADMIN_TOKEN=change-me-admin-token
PORTHOOK_CONTROL_VALIDATOR_TOKEN=change-me-validator-token

# Public tunnel domain. Wildcard DNS for *.tunnels.example.com must point at
# the reverse proxy running in this Compose stack.
PORTHOOK_ROOT_DOMAIN=tunnels.example.com
PORTHOOK_PUBLIC_URL=https://tunnels.example.com

# Dedicated hostnames for agent WebSocket connections and the control plane.
PORTHOOK_AGENT_DOMAIN=agent.example.com
PORTHOOK_CONTROL_DOMAIN=control.example.com

# Host ports exposed by the reverse proxy. The gateway and control plane are
# only exposed inside the Compose network.
PORTHOOK_HTTP_PORT=80
PORTHOOK_HTTPS_PORT=443

# Absolute host paths for the wildcard certificate and private key mounted
# into the reverse proxy container.
PORTHOOK_TLS_CERT_PATH=/etc/letsencrypt/live/tunnels.example.com/fullchain.pem
PORTHOOK_TLS_KEY_PATH=/etc/letsencrypt/live/tunnels.example.com/privkey.pem

